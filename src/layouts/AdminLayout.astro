---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Panel admin — RemaTech' } = Astro.props;
const path = Astro.url.pathname;
const user = Astro.locals.user;

const allLinks = [
  {
    href: '/admin',
    label: 'Dashboard',
    icon: 'M3 13h8V3H3zM13 21h8V11h-8zM13 3v5h8V3zM3 21h8v-5H3z',
    exact: true,
    adminOnly: false,
  },
  {
    href: '/admin/pedidos',
    label: 'Pedidos',
    icon: 'M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4ZM3 6h18M16 10a4 4 0 0 1-8 0',
    exact: false,
    adminOnly: false,
  },
  {
    href: '/admin/productos',
    label: 'Productos',
    icon: 'm7.5 4.27 9 5.15M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Zm-18-.27 8.88 5.14a2 2 0 0 0 2 0L21 8M12 22V12',
    exact: false,
    adminOnly: false,
  },
  {
    href: '/admin/categorias',
    label: 'Categorías',
    icon: 'M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l7.71 7.71a2.41 2.41 0 0 0 3.408 0l7.3-7.3a2.41 2.41 0 0 0 0-3.41zM7.5 8v-.01',
    exact: false,
    adminOnly: true,
  },
  {
    href: '/admin/usuarios',
    label: 'Usuarios',
    icon: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M9 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z',
    exact: false,
    adminOnly: true,
  },
];

const links = allLinks.filter((l) => !l.adminOnly || user?.is_admin);

function isActive(l: (typeof links)[number]) {
  return l.exact ? path === l.href : path.startsWith(l.href);
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚙️</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-neutral-100 text-neutral-900 antialiased">
    <div class="flex min-h-screen">
      <aside class="fixed inset-y-0 left-0 z-40 flex w-64 flex-col bg-neutral-950 text-neutral-300 max-lg:hidden">
        <a href="/admin" class="flex items-center gap-2 px-6 py-5 font-bold text-white">
          <span class="flex size-8 items-center justify-center rounded-lg bg-gradient-to-br from-neutral-600 to-neutral-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>
          </span>
          <span>RemaTech <span class="text-xs font-medium text-neutral-500">admin</span></span>
        </a>

        <nav class="mt-4 flex-1 space-y-1 px-3">
          {links.map((l) => (
            <a
              href={l.href}
              class:list={[
                'flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-colors',
                isActive(l)
                  ? 'bg-white/10 text-white'
                  : 'hover:bg-neutral-800/60 hover:text-white',
              ]}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5">
                <path d={l.icon} />
              </svg>
              {l.label}
            </a>
          ))}
        </nav>

        <div class="border-t border-neutral-800 p-4">
          <p class="truncate px-2 text-xs text-neutral-500">{user?.email}</p>
          <div class="mt-3 flex gap-2">
            <a
              href="/"
              class="flex-1 rounded-lg border border-neutral-700 px-3 py-2 text-center text-xs font-semibold transition-colors hover:bg-neutral-800"
            >
              Ver tienda
            </a>
            <form method="POST" action="/api/logout" class="flex-1">
              <button
                type="submit"
                class="w-full cursor-pointer rounded-lg bg-neutral-800 px-3 py-2 text-xs font-semibold transition-colors hover:bg-neutral-700"
              >
                Salir
              </button>
            </form>
          </div>
        </div>
      </aside>

      <div class="flex-1 lg:pl-64">
        <header class="sticky top-0 z-30 border-b border-neutral-200 bg-white/80 backdrop-blur-lg lg:hidden">
          <div class="flex h-14 items-center justify-between gap-4 px-4">
            <a href="/admin" class="font-bold">RemaTech <span class="text-xs text-neutral-400">admin</span></a>
            <nav class="flex items-center gap-1 text-sm">
              {links.map((l) => (
                <a
                  href={l.href}
                  class:list={[
                    'rounded-full px-3 py-1.5 font-medium',
                    isActive(l) ? 'bg-neutral-100' : 'text-neutral-500',
                  ]}
                >
                  {l.label}
                </a>
              ))}
            </nav>
          </div>
        </header>

        <main class="mx-auto max-w-6xl p-4 sm:p-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
