---
import BaseLayout from '../layouts/BaseLayout.astro';
import { verifyLogin, createSession } from '../lib/auth';
import { sanitizeNext } from '../lib/util';
import { isRateLimited, recordAttempt, clearAttempts, clientIp } from '../lib/ratelimit';

const next = sanitizeNext(Astro.url.searchParams.get('next'));
if (Astro.locals.user) return Astro.redirect(next);

let error = '';
let email = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  email = String(form.get('email') ?? '').trim().toLowerCase().slice(0, 254);
  const password = String(form.get('password') ?? '').slice(0, 100);

  const ip = clientIp(Astro.request);
  const emailKey = `login:${email}`;
  const ipKey = `login-ip:${ip}`;

  if (!email || !password) {
    error = 'Completá todos los campos.';
  } else if (
    (await isRateLimited(emailKey, 5, 15)) ||
    (await isRateLimited(ipKey, 30, 15))
  ) {
    error = 'Demasiados intentos fallidos. Esperá 15 minutos y volvé a probar.';
  } else {
    const user = await verifyLogin(email, password);
    if (!user) {
      await recordAttempt(emailKey);
      await recordAttempt(ipKey);
      error = 'Email o contraseña incorrectos.';
    } else {
      await clearAttempts(emailKey);
      await createSession(user.id, Astro.cookies);
      return Astro.redirect(sanitizeNext(form.get('next')));
    }
  }
}
---

<BaseLayout title="Ingresar — NoteStore">
  <div class="mx-auto flex max-w-md flex-col px-4 py-16 sm:px-6">
    <div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm sm:p-10">
      <h1 class="text-2xl font-bold tracking-tight">Ingresá a tu cuenta</h1>
      <p class="mt-2 text-sm text-neutral-500">
        ¿No tenés cuenta?
        <a href={`/registro${next !== '/' ? `?next=${encodeURIComponent(next)}` : ''}`} class="font-semibold text-neutral-900 hover:underline">
          Registrate gratis
        </a>
      </p>

      {error && (
        <p class="mt-5 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
      )}

      <form method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="next" value={next} />
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-neutral-700">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            value={email}
            required
            autocomplete="email"
            class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
            placeholder="tu@email.com"
          />
        </div>
        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-neutral-700">Contraseña</label>
          <input
            id="password"
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
        >
          Ingresar
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
