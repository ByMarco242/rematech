---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getDb, type Product, type Category } from '../../lib/db';

const db = await getDb();

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
const categorySlug = Astro.url.searchParams.get('categoria') ?? '';
const orden = Astro.url.searchParams.get('orden') ?? 'nuevo';
const marca = Astro.url.searchParams.get('marca')?.trim() ?? '';
const min = Math.max(Number(Astro.url.searchParams.get('min')) || 0, 0);
const max = Math.max(Number(Astro.url.searchParams.get('max')) || 0, 0);
const soloStock = Astro.url.searchParams.get('stock') === '1';

const [categoriesRes, brandsRes] = await Promise.all([
  db.execute('SELECT * FROM categories ORDER BY name'),
  db.execute("SELECT DISTINCT brand FROM products WHERE brand != '' ORDER BY brand"),
]);
const categories = categoriesRes.rows as unknown as Category[];
const brands = brandsRes.rows.map((r) => String(r.brand));

let sql = `SELECT p.*, c.name AS category_name, c.slug AS category_slug
           FROM products p LEFT JOIN categories c ON c.id = p.category_id WHERE 1=1`;
const args: (string | number)[] = [];

if (q) {
  sql += ' AND (p.name LIKE ? OR p.brand LIKE ? OR p.description LIKE ?)';
  args.push(`%${q}%`, `%${q}%`, `%${q}%`);
}
if (categorySlug) {
  sql += ' AND c.slug = ?';
  args.push(categorySlug);
}
if (marca) {
  sql += ' AND p.brand = ?';
  args.push(marca);
}
if (min > 0) {
  sql += ' AND p.price >= ?';
  args.push(min);
}
if (max > 0) {
  sql += ' AND p.price <= ?';
  args.push(max);
}
if (soloStock) {
  sql += ' AND p.stock > 0';
}

const hasFilters = Boolean(q || categorySlug || marca || min > 0 || max > 0 || soloStock);

if (orden === 'precio-asc') sql += ' ORDER BY p.price ASC';
else if (orden === 'precio-desc') sql += ' ORDER BY p.price DESC';
else sql += ' ORDER BY p.created_at DESC, p.id DESC';

const productsRes = await db.execute({ sql, args });
const products = productsRes.rows as unknown as Product[];
---

<BaseLayout title="Notebooks — NoteStore">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight">Todas las notebooks</h1>
    <p class="mt-2 text-neutral-500">
      {products.length} {products.length === 1 ? 'resultado' : 'resultados'}
      {q && <span> para «{q}»</span>}
    </p>

    <form method="GET" class="mt-8 flex flex-wrap items-center gap-3">
      <div class="relative min-w-60 flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute top-1/2 left-4 size-4.5 -translate-y-1/2 text-neutral-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar por nombre, marca..."
          class="w-full rounded-full border border-neutral-200 bg-white py-2.5 pr-4 pl-11 text-sm shadow-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
        />
      </div>
      <select
        name="categoria"
        class="rounded-full border border-neutral-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none focus:border-neutral-500"
      >
        <option value="">Todas las categorías</option>
        {categories.map((c) => (
          <option value={c.slug} selected={c.slug === categorySlug}>{c.name}</option>
        ))}
      </select>
      {brands.length > 0 && (
        <select
          name="marca"
          class="rounded-full border border-neutral-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none focus:border-neutral-500"
        >
          <option value="">Todas las marcas</option>
          {brands.map((b) => (
            <option value={b} selected={b === marca}>{b}</option>
          ))}
        </select>
      )}
      <select
        name="orden"
        class="rounded-full border border-neutral-200 bg-white px-4 py-2.5 text-sm shadow-sm outline-none focus:border-neutral-500"
      >
        <option value="nuevo" selected={orden === 'nuevo'}>Más nuevos</option>
        <option value="precio-asc" selected={orden === 'precio-asc'}>Menor precio</option>
        <option value="precio-desc" selected={orden === 'precio-desc'}>Mayor precio</option>
      </select>
      <div class="flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-4 py-2 text-sm shadow-sm">
        <span class="text-neutral-500">Gs.</span>
        <input
          type="number"
          name="min"
          value={min > 0 ? min : ''}
          placeholder="Mínimo"
          min="0"
          step="100000"
          class="w-24 outline-none [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none"
        />
        <span class="text-neutral-300">—</span>
        <input
          type="number"
          name="max"
          value={max > 0 ? max : ''}
          placeholder="Máximo"
          min="0"
          step="100000"
          class="w-24 outline-none [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none"
        />
      </div>
      <label class="flex cursor-pointer items-center gap-2 rounded-full border border-neutral-200 bg-white px-4 py-2.5 text-sm shadow-sm">
        <input type="checkbox" name="stock" value="1" checked={soloStock} class="accent-neutral-900" />
        Solo con stock
      </label>
      <button
        type="submit"
        class="cursor-pointer rounded-full bg-neutral-900 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-neutral-700"
      >
        Filtrar
      </button>
      {hasFilters && (
        <a href="/productos" class="text-sm font-semibold text-neutral-500 hover:text-neutral-900 hover:underline">
          Limpiar filtros
        </a>
      )}
    </form>

    {products.length === 0 ? (
      <div class="mt-16 rounded-2xl border border-dashed border-neutral-300 p-16 text-center">
        <p class="text-lg font-semibold text-neutral-700">No encontramos resultados</p>
        <p class="mt-1 text-neutral-500">Probá con otra búsqueda o quitá los filtros.</p>
        <a href="/productos" class="mt-5 inline-block rounded-full bg-neutral-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-neutral-700">
          Ver todo el catálogo
        </a>
      </div>
    ) : (
      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
        {products.map((p) => (
          <ProductCard product={p} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
