---
import BaseLayout from '../layouts/BaseLayout.astro';

const waNumber = (
  process.env.WHATSAPP_NUMBER ||
  import.meta.env.WHATSAPP_NUMBER ||
  '595971000000'
).replace(/[^0-9]/g, '');

const waDisplay = `+${waNumber}`;

// Ubicación del local: coordenadas del pin de Google Maps y enlace para abrir la app
const storeAddress = 'San José, San Lorenzo, Paraguay';
const storeCoords = '-25.3390268,-57.4966736';
const storeMapsLink = 'https://maps.app.goo.gl/GWQq95BiAibTRiAP6';
const mapSrc = `https://www.google.com/maps?q=${storeCoords}&z=16&output=embed&hl=es`;

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<BaseLayout
  title="Contacto — NoteStore"
  description="Contactanos por WhatsApp o envianos tu consulta. Estamos para ayudarte a elegir tu próxima notebook."
>
  <section class="relative overflow-hidden bg-neutral-950 text-white">
    <div class="absolute -top-40 -left-40 size-96 rounded-full bg-white/10 blur-[120px]"></div>
    <div class="absolute -right-40 -bottom-40 size-96 rounded-full bg-white/5 blur-[120px]"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <h1 class="animate-fade-up text-4xl font-extrabold tracking-tight sm:text-5xl">Contacto</h1>
      <p class="animate-fade-up anim-delay-1 mt-3 max-w-xl text-lg text-neutral-400">
        ¿Tenés dudas sobre un producto, tu pedido o querés asesoramiento?
        Escribinos y te respondemos a la brevedad.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="space-y-5" data-reveal-group>
        <a
          href={`https://wa.me/${waNumber}`}
          target="_blank"
          rel="noopener"
          class="group flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5.5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.1-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          </span>
          <div>
            <h2 class="font-bold">WhatsApp</h2>
            <p class="mt-0.5 text-sm text-neutral-500">Respuesta rápida en horario comercial</p>
            <p class="mt-1.5 text-sm font-semibold group-hover:underline">{waDisplay}</p>
          </div>
        </a>

        <div class="flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <span class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-neutral-100 text-neutral-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </span>
          <div>
            <h2 class="font-bold">Email</h2>
            <p class="mt-0.5 text-sm text-neutral-500">Para consultas y presupuestos</p>
            <a href="mailto:contacto@notestore.com" class="mt-1.5 block text-sm font-semibold hover:underline">
              contacto@notestore.com
            </a>
          </div>
        </div>

        <div class="flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <span class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-neutral-100 text-neutral-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <div>
            <h2 class="font-bold">Horario de atención</h2>
            <p class="mt-0.5 text-sm text-neutral-500">Lunes a viernes: 8:00 — 18:00</p>
            <p class="text-sm text-neutral-500">Sábados: 8:00 — 12:00</p>
          </div>
        </div>

        <a
          href={storeMapsLink}
          target="_blank"
          rel="noopener"
          class="group flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-neutral-100 text-neutral-900">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5.5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div>
            <h2 class="font-bold">Ubicación</h2>
            <p class="mt-0.5 text-sm text-neutral-500">Visitanos en nuestro local</p>
            <p class="mt-1.5 text-sm font-semibold group-hover:underline">{storeAddress}</p>
          </div>
        </a>
      </div>

      <div class="lg:col-span-2" data-reveal>
        <div class="rounded-2xl border border-neutral-200 bg-white p-7 shadow-sm sm:p-9">
          <h2 class="text-xl font-bold tracking-tight">Envianos tu consulta</h2>
          <p class="mt-1 text-sm text-neutral-500">
            Completá el formulario y el mensaje se abre directo en nuestro WhatsApp.
          </p>

          <form id="contact-form" class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
              <label for="c-name" class="mb-1.5 block text-sm font-medium text-neutral-700">Nombre *</label>
              <input id="c-name" name="name" required class={input} placeholder="Tu nombre" />
            </div>
            <div>
              <label for="c-topic" class="mb-1.5 block text-sm font-medium text-neutral-700">Motivo</label>
              <select id="c-topic" name="topic" class={input}>
                <option>Consulta sobre un producto</option>
                <option>Estado de mi pedido</option>
                <option>Garantía o soporte técnico</option>
                <option>Otro</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <label for="c-message" class="mb-1.5 block text-sm font-medium text-neutral-700">Mensaje *</label>
              <textarea
                id="c-message"
                name="message"
                rows="5"
                required
                class={input}
                placeholder="Contanos en qué te podemos ayudar..."></textarea>
            </div>
            <div class="sm:col-span-2">
              <button
                type="submit"
                class="flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-emerald-600 py-3.5 font-semibold text-white transition-colors hover:bg-emerald-500 sm:w-auto sm:px-10"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.1-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                Enviar por WhatsApp
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <section class="mt-10" data-reveal>
      <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
        <iframe
          src={mapSrc}
          title={`Mapa de ubicación: ${storeAddress}`}
          class="h-100 w-full border-0 sm:h-120"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ waNumber }}>
    document.getElementById('contact-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target;
      const name = form.name.value.trim();
      const topic = form.topic.value;
      const message = form.message.value.trim();
      if (!name || !message) return;

      const lines = [
        `¡Hola NoteStore! 👋`,
        '',
        `Motivo: ${topic}`,
        message,
        '',
        `Mi nombre: ${name}`,
      ];
      const url = `https://wa.me/${waNumber}?text=${encodeURIComponent(lines.join('\n'))}`;
      window.open(url, '_blank');
      window.showToast('Abriendo WhatsApp...');
    });
  </script>
</BaseLayout>
