---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getDb, type Product, type Category } from '../../lib/db';

const db = await getDb();
const { slug } = Astro.params;

const catRes = await db.execute({
  sql: 'SELECT * FROM categories WHERE slug = ?',
  args: [slug ?? ''],
});
const category = catRes.rows[0] as unknown as Category | undefined;
if (!category) return Astro.redirect('/productos');

const productsRes = await db.execute({
  sql: `SELECT p.*, c.name AS category_name, c.slug AS category_slug
        FROM products p LEFT JOIN categories c ON c.id = p.category_id
        WHERE p.category_id = ? ORDER BY p.created_at DESC`,
  args: [category.id],
});
const products = productsRes.rows as unknown as Product[];
---

<BaseLayout title={`${category.name} — NoteStore`} description={category.description}>
  <section class="relative overflow-hidden bg-neutral-950">
    <img
      src={category.image_url}
      alt={category.name}
      class="absolute inset-0 size-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/60 to-neutral-950/30"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6">
      <nav class="flex items-center gap-2 text-sm text-neutral-400">
        <a href="/" class="hover:text-white">Inicio</a>
        <span>/</span>
        <a href="/#categorias" class="hover:text-white">Categorías</a>
      </nav>
      <h1 class="animate-fade-up mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">{category.name}</h1>
      <p class="animate-fade-up anim-delay-1 mt-3 max-w-xl text-lg text-neutral-300">{category.description}</p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
    {products.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-neutral-300 p-16 text-center">
        <p class="text-lg font-semibold text-neutral-700">Todavía no hay productos en esta categoría</p>
        <a href="/productos" class="mt-5 inline-block rounded-full bg-neutral-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-neutral-700">
          Ver todo el catálogo
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
        {products.map((p) => (
          <ProductCard product={p} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
