---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb, type Order, type OrderItem } from '../lib/db';
import { formatPrice } from '../lib/util';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login?next=/cuenta');

const db = await getDb();
let saved = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const name = String(form.get('name') ?? '').trim().slice(0, 80);
  const phone = String(form.get('phone') ?? '').trim().slice(0, 30);
  const address = String(form.get('address') ?? '').trim().slice(0, 200);
  if (name) {
    await db.execute({
      sql: 'UPDATE users SET name = ?, phone = ?, address = ? WHERE id = ?',
      args: [name, phone, address, user.id],
    });
    saved = true;
  }
}

const meRes = await db.execute({
  sql: 'SELECT name, email, phone, address FROM users WHERE id = ?',
  args: [user.id],
});
const me = meRes.rows[0];

const ordersRes = await db.execute({
  sql: 'SELECT * FROM orders WHERE user_id = ? ORDER BY id DESC LIMIT 50',
  args: [user.id],
});
const orders = ordersRes.rows as unknown as Order[];

let itemsByOrder = new Map<number, OrderItem[]>();
if (orders.length > 0) {
  const placeholders = orders.map(() => '?').join(',');
  const itemsRes = await db.execute({
    sql: `SELECT * FROM order_items WHERE order_id IN (${placeholders}) ORDER BY id`,
    args: orders.map((o) => o.id),
  });
  for (const row of itemsRes.rows as unknown as OrderItem[]) {
    const list = itemsByOrder.get(row.order_id) ?? [];
    list.push(row);
    itemsByOrder.set(row.order_id, list);
  }
}

const statusInfo: Record<string, { style: string; label: string }> = {
  pendiente: { style: 'bg-amber-50 text-amber-600', label: 'Pendiente de confirmación' },
  aprobado: { style: 'bg-emerald-50 text-emerald-600', label: 'Confirmado' },
  enviado: { style: 'bg-sky-50 text-sky-600', label: 'Enviado' },
  entregado: { style: 'bg-emerald-100 text-emerald-700', label: 'Entregado' },
  cancelado: { style: 'bg-neutral-100 text-neutral-500', label: 'Cancelado' },
  rechazado: { style: 'bg-rose-50 text-rose-600', label: 'Rechazado' },
};

const dateFmt = new Intl.DateTimeFormat('es-PY', {
  dateStyle: 'short',
  timeStyle: 'short',
  timeZone: 'America/Asuncion',
});
function formatDate(sqlDate: string): string {
  return dateFmt.format(new Date(sqlDate.replace(' ', 'T') + 'Z'));
}

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<BaseLayout title="Mi cuenta — NoteStore">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight">Mi cuenta</h1>

    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      <div>
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="font-bold">Mis datos</h2>
          {saved && (
            <p class="mt-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
              Datos actualizados ✓
            </p>
          )}
          <form method="POST" class="mt-4 space-y-4">
            <div>
              <label for="c-name" class="mb-1.5 block text-sm font-medium text-neutral-700">Nombre</label>
              <input id="c-name" name="name" required value={String(me?.name ?? '')} class={input} />
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-medium text-neutral-700">Email</label>
              <input value={String(me?.email ?? '')} disabled class:list={[input, 'bg-neutral-50 text-neutral-400']} />
            </div>
            <div>
              <label for="c-phone" class="mb-1.5 block text-sm font-medium text-neutral-700">Teléfono</label>
              <input id="c-phone" name="phone" value={String(me?.phone ?? '')} class={input} placeholder="+595 9xx xxx xxx" />
              <p class="mt-1 text-xs text-neutral-400">Lo usamos para coordinar la entrega de tus pedidos.</p>
            </div>
            <div>
              <label for="c-address" class="mb-1.5 block text-sm font-medium text-neutral-700">Dirección</label>
              <textarea id="c-address" name="address" rows="2" class={input} placeholder="Calle, número, ciudad">{String(me?.address ?? '')}</textarea>
            </div>
            <button
              type="submit"
              class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
            >
              Guardar
            </button>
          </form>
        </div>
      </div>

      <div class="lg:col-span-2">
        <h2 class="font-bold">Mis pedidos</h2>
        {orders.length === 0 ? (
          <div class="mt-4 rounded-2xl border border-dashed border-neutral-300 p-12 text-center">
            <p class="font-semibold text-neutral-700">Todavía no hiciste ningún pedido</p>
            <a href="/productos" class="mt-4 inline-block rounded-full bg-neutral-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-neutral-700">
              Ver notebooks
            </a>
          </div>
        ) : (
          <div class="mt-4 space-y-4">
            {orders.map((o) => {
              const info = statusInfo[o.status] ?? statusInfo.pendiente;
              return (
                <article class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
                  <header class="flex flex-wrap items-center gap-x-4 gap-y-2">
                    <p class="font-bold">Pedido #{o.id}</p>
                    <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-semibold', info.style]}>
                      {info.label}
                    </span>
                    <p class="text-sm text-neutral-500">{formatDate(o.created_at)}</p>
                    <p class="ml-auto font-extrabold">{formatPrice(o.total)}</p>
                  </header>
                  <ul class="mt-3 divide-y divide-neutral-100 border-t border-neutral-100">
                    {(itemsByOrder.get(o.id) ?? []).map((item) => (
                      <li class="flex items-center justify-between gap-3 py-2 text-sm">
                        <span>
                          {item.product_name}
                          <span class="ml-1 rounded-md bg-neutral-100 px-1.5 py-0.5 text-xs font-semibold text-neutral-600">
                            x{item.qty}
                          </span>
                        </span>
                        <span class="whitespace-nowrap text-neutral-500">{formatPrice(item.price * item.qty)}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
