---
import BaseLayout from '../layouts/BaseLayout.astro';
import { verifyPasswordReset, resetPassword, validatePassword } from '../lib/auth';

if (Astro.locals.user) return Astro.redirect('/');

const token = Astro.url.searchParams.get('token') ?? '';
let error = '';
let done = false;

const userId = token ? await verifyPasswordReset(token) : null;

if (Astro.request.method === 'POST' && userId !== null) {
  const form = await Astro.request.formData();
  const password = String(form.get('password') ?? '').slice(0, 100);
  const confirm = String(form.get('confirm') ?? '').slice(0, 100);

  const pwError = validatePassword(password);
  if (pwError) {
    error = pwError;
  } else if (password !== confirm) {
    error = 'Las contraseñas no coinciden.';
  } else {
    await resetPassword(userId, password);
    done = true;
  }
}
---

<BaseLayout title="Nueva contraseña — NoteStore">
  <div class="mx-auto flex max-w-md flex-col px-4 py-16 sm:px-6">
    <div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm sm:p-10">
      <h1 class="text-2xl font-bold tracking-tight">Nueva contraseña</h1>

      {done ? (
        <div class="mt-5 rounded-xl bg-emerald-50 px-4 py-4 text-sm text-emerald-700">
          <p class="font-semibold">¡Contraseña actualizada! ✓</p>
          <p class="mt-1">Ya podés ingresar con tu contraseña nueva.</p>
          <a href="/login" class="mt-3 inline-block rounded-full bg-emerald-600 px-6 py-2 font-semibold text-white hover:bg-emerald-500">
            Ir a ingresar
          </a>
        </div>
      ) : userId === null ? (
        <div class="mt-5 rounded-xl bg-rose-50 px-4 py-4 text-sm text-rose-600">
          <p class="font-semibold">Enlace inválido o vencido</p>
          <p class="mt-1">
            Los enlaces valen 1 hora. Pedí uno nuevo desde
            <a href="/recuperar" class="font-semibold underline">recuperar contraseña</a>.
          </p>
        </div>
      ) : (
        <>
          <p class="mt-2 text-sm text-neutral-500">
            Elegí tu nueva contraseña: mínimo 8 caracteres, con mayúscula, minúscula y número.
          </p>
          {error && (
            <p class="mt-5 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
          )}
          <form method="POST" class="mt-6 space-y-4">
            <div>
              <label for="password" class="mb-1.5 block text-sm font-medium text-neutral-700">Nueva contraseña</label>
              <input
                id="password"
                type="password"
                name="password"
                required
                minlength="8"
                maxlength="100"
                autocomplete="new-password"
                class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
              />
            </div>
            <div>
              <label for="confirm" class="mb-1.5 block text-sm font-medium text-neutral-700">Repetir contraseña</label>
              <input
                id="confirm"
                type="password"
                name="confirm"
                required
                minlength="8"
                maxlength="100"
                autocomplete="new-password"
                class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
              />
            </div>
            <button
              type="submit"
              class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
            >
              Guardar contraseña
            </button>
          </form>
        </>
      )}
    </div>
  </div>
</BaseLayout>
