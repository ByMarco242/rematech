---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';
import { recordStockMove } from '../../lib/orders';

const db = await getDb();
const me = Astro.locals.user!;

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const productId = Number(form.get('product_id'));
  const type = String(form.get('type') ?? 'entrada');
  const qty = Math.floor(Number(form.get('qty')));
  const note = String(form.get('note') ?? '').trim().slice(0, 200);

  if (!Number.isInteger(productId) || !Number.isFinite(qty) || qty <= 0) {
    error = 'Cantidad inválida.';
  } else {
    const res = await db.execute({
      sql: 'SELECT id, name, stock FROM products WHERE id = ?',
      args: [productId],
    });
    const product = res.rows[0];
    if (!product) {
      error = 'Producto no encontrado.';
    } else {
      const change = type === 'salida' ? -qty : qty;
      if (change < 0 && Number(product.stock) + change < 0) {
        error = `No podés restar ${qty}: el stock actual de «${product.name}» es ${product.stock}.`;
      } else {
        await db.execute({
          sql: 'UPDATE products SET stock = stock + ? WHERE id = ?',
          args: [change, productId],
        });
        const reason = type === 'salida' ? 'Ajuste — salida' : 'Entrada de mercadería';
        await recordStockMove(productId, String(product.name), change, reason, me.name, note);
        return Astro.redirect('/admin/inventario');
      }
    }
  }
}

const [productsRes, movesRes, lowRes] = await Promise.all([
  db.execute('SELECT id, name, stock, min_stock FROM products ORDER BY name'),
  db.execute(
    `SELECT * FROM stock_moves ORDER BY id DESC LIMIT 50`
  ),
  db.execute(
    `SELECT name, stock, min_stock FROM products
     WHERE stock <= 0 OR (min_stock > 0 AND stock <= min_stock)
     ORDER BY stock ASC`
  ),
]);

const products = productsRes.rows as unknown as {
  id: number;
  name: string;
  stock: number;
  min_stock: number;
}[];
const moves = movesRes.rows as unknown as {
  id: number;
  product_name: string;
  change: number;
  reason: string;
  note: string;
  user_name: string;
  created_at: string;
}[];
const lowStock = lowRes.rows as unknown as { name: string; stock: number; min_stock: number }[];

const dateFmt = new Intl.DateTimeFormat('es-PY', {
  dateStyle: 'short',
  timeStyle: 'short',
  timeZone: 'America/Asuncion',
});
function formatDate(sqlDate: string): string {
  return dateFmt.format(new Date(sqlDate.replace(' ', 'T') + 'Z'));
}

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<AdminLayout title="Inventario — NoteStore admin">
  <h1 class="text-2xl font-bold tracking-tight">Inventario</h1>
  <p class="mt-1 text-sm text-neutral-500">
    Entradas de mercadería, ajustes y el historial completo de movimientos de stock.
    Las ventas y cancelaciones se registran automáticamente.
  </p>

  {lowStock.length > 0 && (
    <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
      <p class="font-semibold">⚠️ Stock crítico:</p>
      <p class="mt-1">
        {lowStock.map((p) => `${p.name} (${p.stock})`).join(' · ')}
      </p>
    </div>
  )}

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    <div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
        <h2 class="font-bold">Registrar movimiento</h2>
        {error && (
          <p class="mt-4 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
        )}
        <form method="POST" class="mt-4 space-y-4">
          <div>
            <label for="inv-product" class="mb-1.5 block text-sm font-medium text-neutral-700">Producto</label>
            <select id="inv-product" name="product_id" required class={input}>
              {products.map((p) => (
                <option value={p.id}>{p.name} — stock: {p.stock}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="inv-type" class="mb-1.5 block text-sm font-medium text-neutral-700">Tipo</label>
            <select id="inv-type" name="type" class={input}>
              <option value="entrada">Entrada (compra a proveedor, devolución)</option>
              <option value="salida">Salida (rotura, pérdida, uso interno)</option>
            </select>
          </div>
          <div>
            <label for="inv-qty" class="mb-1.5 block text-sm font-medium text-neutral-700">Cantidad</label>
            <input id="inv-qty" name="qty" type="number" min="1" required class={input} placeholder="Ej: 5" />
          </div>
          <div>
            <label for="inv-note" class="mb-1.5 block text-sm font-medium text-neutral-700">Nota</label>
            <input id="inv-note" name="note" class={input} placeholder="Ej: Factura proveedor 001-123" />
          </div>
          <button
            type="submit"
            class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
          >
            Registrar
          </button>
        </form>
        <p class="mt-3 text-xs text-neutral-400">
          El stock mínimo de alerta se configura en la edición de cada producto.
        </p>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="overflow-x-auto rounded-2xl border border-neutral-200 bg-white shadow-sm">
        <table class="w-full min-w-140 text-sm">
          <thead class="border-b border-neutral-200 bg-neutral-50 text-left text-xs text-neutral-500 uppercase">
            <tr>
              <th class="px-5 py-3 font-medium">Fecha</th>
              <th class="px-5 py-3 font-medium">Producto</th>
              <th class="px-5 py-3 font-medium">Cambio</th>
              <th class="px-5 py-3 font-medium">Motivo</th>
              <th class="px-5 py-3 font-medium">Usuario</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {moves.length === 0 ? (
              <tr><td colspan="5" class="p-10 text-center text-neutral-500">Todavía no hay movimientos.</td></tr>
            ) : (
              moves.map((m) => (
                <tr class="transition-colors hover:bg-neutral-50">
                  <td class="px-5 py-3 whitespace-nowrap text-neutral-500">{formatDate(m.created_at)}</td>
                  <td class="px-5 py-3">{m.product_name}</td>
                  <td class="px-5 py-3">
                    <span class:list={[
                      'rounded-full px-2.5 py-0.5 text-xs font-bold',
                      m.change > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600',
                    ]}>
                      {m.change > 0 ? `+${m.change}` : m.change}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-neutral-500">
                    {m.reason}
                    {m.note && <span class="block text-xs text-neutral-400">{m.note}</span>}
                  </td>
                  <td class="px-5 py-3 text-neutral-500">{m.user_name}</td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>
