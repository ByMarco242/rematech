---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb, type Order, type OrderItem } from '../../lib/db';
import { formatPrice } from '../../lib/util';
import { approveOrder, advanceOrder, rejectOrder, cancelOrder } from '../../lib/orders';

const db = await getDb();
const me = Astro.locals.user!;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');
  const id = Number(form.get('id'));

  if (Number.isInteger(id)) {
    if (action === 'approve') await approveOrder(id, me);
    else if (action === 'reject') await rejectOrder(id);
    else if (action === 'ship') await advanceOrder(id, 'enviado');
    else if (action === 'deliver') await advanceOrder(id, 'entregado');
    else if (action === 'cancel') await cancelOrder(id, me);
  }
  return Astro.redirect('/admin/pedidos');
}

const filter = Astro.url.searchParams.get('estado') ?? '';
const VALID = ['pendiente', 'aprobado', 'enviado', 'entregado', 'cancelado', 'rechazado'];
const validFilter = VALID.includes(filter) ? filter : '';

const ordersRes = validFilter
  ? await db.execute({
      sql: 'SELECT * FROM orders WHERE status = ? ORDER BY id DESC LIMIT 100',
      args: [validFilter],
    })
  : await db.execute('SELECT * FROM orders ORDER BY id DESC LIMIT 100');
const orders = ordersRes.rows as unknown as Order[];

let itemsByOrder = new Map<number, OrderItem[]>();
if (orders.length > 0) {
  const placeholders = orders.map(() => '?').join(',');
  const itemsRes = await db.execute({
    sql: `SELECT * FROM order_items WHERE order_id IN (${placeholders}) ORDER BY id`,
    args: orders.map((o) => o.id),
  });
  for (const row of itemsRes.rows as unknown as OrderItem[]) {
    const list = itemsByOrder.get(row.order_id) ?? [];
    list.push(row);
    itemsByOrder.set(row.order_id, list);
  }
}

const statusStyle: Record<string, string> = {
  pendiente: 'bg-amber-50 text-amber-600',
  aprobado: 'bg-emerald-50 text-emerald-600',
  enviado: 'bg-sky-50 text-sky-600',
  entregado: 'bg-emerald-100 text-emerald-700',
  cancelado: 'bg-neutral-100 text-neutral-500',
  rechazado: 'bg-rose-50 text-rose-600',
};

const dateFmt = new Intl.DateTimeFormat('es-PY', {
  dateStyle: 'short',
  timeStyle: 'short',
  timeZone: 'America/Asuncion',
});

function formatDate(sqlDate: string): string {
  return dateFmt.format(new Date(sqlDate.replace(' ', 'T') + 'Z'));
}

const filters = [
  { value: '', label: 'Todos' },
  { value: 'pendiente', label: 'Pendientes' },
  { value: 'aprobado', label: 'Aprobados' },
  { value: 'enviado', label: 'Enviados' },
  { value: 'entregado', label: 'Entregados' },
  { value: 'cancelado', label: 'Cancelados' },
  { value: 'rechazado', label: 'Rechazados' },
];

const btn = 'flex-1 cursor-pointer rounded-full px-4 py-2 text-sm font-semibold transition-colors';
---

<AdminLayout title="Pedidos — NoteStore admin">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Pedidos</h1>
      <p class="mt-1 text-sm text-neutral-500">
        Aprobar descuenta stock y asigna nº de comprobante. Cancelar una venta repone el stock.
      </p>
    </div>
    <a
      href="/admin/pos"
      class="rounded-full bg-neutral-900 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-neutral-700"
    >
      + Venta manual
    </a>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {filters.map((f) => (
      <a
        href={f.value ? `/admin/pedidos?estado=${f.value}` : '/admin/pedidos'}
        class:list={[
          'rounded-full px-4 py-1.5 text-sm font-medium transition-colors',
          validFilter === f.value
            ? 'bg-neutral-900 text-white'
            : 'border border-neutral-200 bg-white text-neutral-600 hover:bg-neutral-50',
        ]}
      >
        {f.label}
      </a>
    ))}
  </div>

  {orders.length === 0 ? (
    <div class="mt-8 rounded-2xl border border-dashed border-neutral-300 bg-white p-16 text-center">
      <p class="text-lg font-semibold text-neutral-700">No hay pedidos{validFilter && ` con estado «${validFilter}»`}</p>
      <p class="mt-1 text-sm text-neutral-500">
        Los pedidos del carrito y las ventas manuales aparecen acá.
      </p>
    </div>
  ) : (
    <div class="mt-8 space-y-5">
      {orders.map((o) => (
        <article class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
          <header class="flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-neutral-100 bg-neutral-50/60 px-5 py-4">
            <p class="font-bold">Pedido #{o.id}</p>
            <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize', statusStyle[o.status]]}>
              {o.status}
            </span>
            {o.source === 'manual' && (
              <span class="rounded-full bg-neutral-900 px-2.5 py-0.5 text-xs font-semibold text-white">Mostrador</span>
            )}
            {o.invoice_number && (
              <span class="text-xs font-semibold text-neutral-400">Comprobante Nº {String(o.invoice_number).padStart(7, '0')}</span>
            )}
            <p class="text-sm text-neutral-500">{formatDate(o.created_at)}</p>
            <div class="ml-auto text-right">
              <p class="text-xs text-neutral-400 uppercase">Total</p>
              <p class="font-extrabold">{formatPrice(o.total)}</p>
            </div>
          </header>

          <div class="grid gap-5 px-5 py-4 md:grid-cols-3">
            <div class="md:col-span-2">
              <ul class="divide-y divide-neutral-100">
                {(itemsByOrder.get(o.id) ?? []).map((item) => (
                  <li class="flex items-center justify-between gap-3 py-2 text-sm">
                    <span>
                      {item.product_name}
                      <span class="ml-1 rounded-md bg-neutral-100 px-1.5 py-0.5 text-xs font-semibold text-neutral-600">
                        x{item.qty}
                      </span>
                    </span>
                    <span class="font-semibold whitespace-nowrap">{formatPrice(item.price * item.qty)}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="flex flex-col justify-between gap-4 md:border-l md:border-neutral-100 md:pl-5">
              <div class="text-sm">
                <p class="text-xs text-neutral-400 uppercase">Cliente</p>
                <p class="mt-1 font-semibold">{o.customer_name}</p>
                {o.customer_email && <p class="text-neutral-500">{o.customer_email}</p>}
                {o.customer_phone && <p class="text-neutral-500">📞 {o.customer_phone}</p>}
                {o.customer_ruc && <p class="text-neutral-500">RUC: {o.customer_ruc}</p>}
              </div>

              <div class="flex flex-wrap gap-2">
                {o.status === 'pendiente' && (
                  <>
                    <form method="POST" class="flex-1">
                      <input type="hidden" name="_action" value="approve" />
                      <input type="hidden" name="id" value={o.id} />
                      <button type="submit" class:list={[btn, 'w-full bg-emerald-600 text-white hover:bg-emerald-500']}>
                        Aprobar
                      </button>
                    </form>
                    <form method="POST" class="flex-1" onsubmit={`return confirm('¿Rechazar el pedido #${o.id}?')`}>
                      <input type="hidden" name="_action" value="reject" />
                      <input type="hidden" name="id" value={o.id} />
                      <button type="submit" class:list={[btn, 'w-full border border-rose-200 text-rose-600 hover:bg-rose-50']}>
                        Rechazar
                      </button>
                    </form>
                  </>
                )}
                {o.status === 'aprobado' && (
                  <form method="POST" class="flex-1">
                    <input type="hidden" name="_action" value="ship" />
                    <input type="hidden" name="id" value={o.id} />
                    <button type="submit" class:list={[btn, 'w-full bg-sky-600 text-white hover:bg-sky-500']}>
                      Marcar enviado
                    </button>
                  </form>
                )}
                {(o.status === 'aprobado' || o.status === 'enviado') && (
                  <form method="POST" class="flex-1">
                    <input type="hidden" name="_action" value="deliver" />
                    <input type="hidden" name="id" value={o.id} />
                    <button type="submit" class:list={[btn, 'w-full bg-emerald-700 text-white hover:bg-emerald-600']}>
                      Marcar entregado
                    </button>
                  </form>
                )}
                {['aprobado', 'enviado', 'entregado'].includes(o.status) && (
                  <>
                    <a
                      href={`/admin/factura/${o.id}`}
                      target="_blank"
                      class:list={[btn, 'border border-neutral-200 text-center text-neutral-700 hover:bg-neutral-50']}
                    >
                      Factura
                    </a>
                    <form
                      method="POST"
                      class="flex-1"
                      onsubmit={`return confirm('¿Cancelar el pedido #${o.id}? Se repone el stock de sus productos.')`}
                    >
                      <input type="hidden" name="_action" value="cancel" />
                      <input type="hidden" name="id" value={o.id} />
                      <button type="submit" class:list={[btn, 'w-full border border-rose-200 text-rose-600 hover:bg-rose-50']}>
                        Cancelar
                      </button>
                    </form>
                  </>
                )}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  )}
</AdminLayout>
