---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSettings, saveSetting, SETTING_KEYS } from '../../lib/orders';

let saved = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  for (const key of SETTING_KEYS) {
    await saveSetting(key, String(form.get(key) ?? '').trim().slice(0, 200));
  }
  saved = true;
}

const settings = await getSettings();

const fields = [
  { key: 'business_name', label: 'Razón social / nombre del negocio', placeholder: 'NoteStore S.R.L.' },
  { key: 'business_ruc', label: 'RUC', placeholder: '80012345-6' },
  { key: 'business_timbrado', label: 'Nº de timbrado', placeholder: '12345678' },
  { key: 'business_address', label: 'Dirección', placeholder: 'San José, San Lorenzo' },
  { key: 'business_phone', label: 'Teléfono', placeholder: '+595 985 752 720' },
];

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<AdminLayout title="Configuración — NoteStore admin">
  <h1 class="text-2xl font-bold tracking-tight">Configuración del negocio</h1>
  <p class="mt-1 text-sm text-neutral-500">
    Estos datos aparecen en los comprobantes de venta (facturas).
  </p>

  <div class="mt-8 max-w-xl">
    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm sm:p-8">
      {saved && (
        <p class="mb-5 rounded-xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
          Configuración guardada ✓
        </p>
      )}
      <form method="POST" class="space-y-4">
        {fields.map((f) => (
          <div>
            <label for={f.key} class="mb-1.5 block text-sm font-medium text-neutral-700">{f.label}</label>
            <input id={f.key} name={f.key} value={settings[f.key]} class={input} placeholder={f.placeholder} />
          </div>
        ))}
        <button
          type="submit"
          class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
        >
          Guardar configuración
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
