---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ProductForm from '../../../components/ProductForm.astro';
import { getDb, type Category, type Product } from '../../../lib/db';
import { parseProductForm, uniqueProductSlug } from '../../../lib/products';

const db = await getDb();
const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect('/admin/productos');

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const parsed = parseProductForm(form);
  if (parsed.error || !parsed.data) {
    error = parsed.error ?? 'Datos inválidos.';
  } else {
    const d = parsed.data;
    const slug = await uniqueProductSlug(d.name, id);
    await db.execute({
      sql: `UPDATE products SET
              name = ?, slug = ?, brand = ?, description = ?, price = ?, old_price = ?,
              cost = ?, image_url = ?, category_id = ?, cpu = ?, ram = ?, storage = ?,
              screen = ?, stock = ?, featured = ?
            WHERE id = ?`,
      args: [
        d.name, slug, d.brand, d.description, d.price, d.old_price, d.cost, d.image_url,
        d.category_id, d.cpu, d.ram, d.storage, d.screen, d.stock, d.featured, id,
      ],
    });
    return Astro.redirect('/admin/productos');
  }
}

const res = await db.execute({ sql: 'SELECT * FROM products WHERE id = ?', args: [id] });
const product = res.rows[0] as unknown as Product | undefined;
if (!product) return Astro.redirect('/admin/productos');

const categoriesRes = await db.execute('SELECT * FROM categories ORDER BY name');
const categories = categoriesRes.rows as unknown as Category[];
---

<AdminLayout title={`Editar ${product.name} — NoteStore admin`}>
  <nav class="text-sm text-neutral-500">
    <a href="/admin/productos" class="hover:text-neutral-900">← Volver a productos</a>
  </nav>
  <div class="mt-3 mb-8 flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight">Editar producto</h1>
    <a href={`/productos/${product.slug}`} target="_blank" class="text-sm font-semibold text-neutral-900 hover:underline">
      Ver en la tienda ↗
    </a>
  </div>
  <ProductForm product={product} categories={categories} error={error} submitLabel="Guardar cambios" />
</AdminLayout>
