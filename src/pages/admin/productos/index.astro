---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb, type Product } from '../../../lib/db';
import { formatPrice } from '../../../lib/util';

const db = await getDb();

const isAdmin = Astro.locals.user?.is_admin ?? false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'delete' && isAdmin) {
    const id = Number(form.get('id'));
    if (Number.isInteger(id)) {
      await db.execute({ sql: 'DELETE FROM products WHERE id = ?', args: [id] });
    }
    return Astro.redirect('/admin/productos');
  }
}

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
let sql = `SELECT p.*, c.name AS category_name FROM products p
           LEFT JOIN categories c ON c.id = p.category_id`;
const args: string[] = [];
if (q) {
  sql += ' WHERE p.name LIKE ? OR p.brand LIKE ?';
  args.push(`%${q}%`, `%${q}%`);
}
sql += ' ORDER BY p.created_at DESC, p.id DESC';

const res = await db.execute({ sql, args });
const products = res.rows as unknown as Product[];
---

<AdminLayout title="Productos — NoteStore admin">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Productos</h1>
      <p class="mt-1 text-sm text-neutral-500">{products.length} productos en el catálogo.</p>
    </div>
    <a
      href="/admin/productos/nuevo"
      class="rounded-full bg-neutral-900 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-neutral-700"
    >
      + Nuevo producto
    </a>
  </div>

  <form method="GET" class="mt-6 flex max-w-md gap-2">
    <input
      type="search"
      name="q"
      value={q}
      placeholder="Buscar producto..."
      class="w-full rounded-full border border-neutral-200 bg-white px-5 py-2.5 text-sm shadow-sm outline-none focus:border-neutral-500"
    />
    <button type="submit" class="cursor-pointer rounded-full bg-neutral-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-neutral-700">
      Buscar
    </button>
  </form>

  <div class="mt-6 overflow-x-auto rounded-2xl border border-neutral-200 bg-white shadow-sm">
    {products.length === 0 ? (
      <p class="p-10 text-center text-neutral-500">No hay productos{q && ` que coincidan con «${q}»`}.</p>
    ) : (
      <table class="w-full min-w-160 text-sm">
        <thead class="border-b border-neutral-200 bg-neutral-50 text-left text-xs text-neutral-500 uppercase">
          <tr>
            <th class="px-5 py-3 font-medium">Producto</th>
            <th class="px-5 py-3 font-medium">Categoría</th>
            <th class="px-5 py-3 font-medium">Precio</th>
            <th class="px-5 py-3 font-medium">Stock</th>
            <th class="px-5 py-3 font-medium">Destacado</th>
            <th class="px-5 py-3 text-right font-medium">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {products.map((p) => (
            <tr class="transition-colors hover:bg-neutral-50">
              <td class="px-5 py-3">
                <div class="flex items-center gap-3">
                  <img src={p.image_url} alt="" class="size-10 shrink-0 rounded-lg object-cover" />
                  <div class="min-w-0">
                    <p class="truncate font-medium">{p.name}</p>
                    <p class="text-xs text-neutral-400">{p.brand}</p>
                  </div>
                </div>
              </td>
              <td class="px-5 py-3 text-neutral-500">{p.category_name ?? '—'}</td>
              <td class="px-5 py-3 font-semibold">{formatPrice(p.price)}</td>
              <td class="px-5 py-3">
                <span
                  class:list={[
                    'rounded-full px-2.5 py-0.5 text-xs font-semibold',
                    p.stock > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600',
                  ]}
                >
                  {p.stock > 0 ? `${p.stock} u.` : 'Sin stock'}
                </span>
              </td>
              <td class="px-5 py-3">{p.featured ? '⭐' : '—'}</td>
              <td class="px-5 py-3">
                <div class="flex items-center justify-end gap-1">
                  <a
                    href={`/productos/${p.slug}`}
                    target="_blank"
                    class="rounded-lg px-3 py-1.5 text-xs font-semibold text-neutral-500 hover:bg-neutral-100"
                  >
                    Ver
                  </a>
                  <a
                    href={`/admin/productos/${p.id}`}
                    class="rounded-lg px-3 py-1.5 text-xs font-semibold text-neutral-900 hover:bg-neutral-100"
                  >
                    Editar
                  </a>
                  {isAdmin && (
                    <form
                      method="POST"
                      onsubmit={`return confirm('¿Eliminar «${p.name.replace(/'/g, '')}»? Esta acción no se puede deshacer.')`}
                    >
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={p.id} />
                      <button type="submit" class="cursor-pointer rounded-lg px-3 py-1.5 text-xs font-semibold text-rose-600 hover:bg-rose-50">
                        Eliminar
                      </button>
                    </form>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
