---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ProductForm from '../../../components/ProductForm.astro';
import { getDb, type Category } from '../../../lib/db';
import { parseProductForm, uniqueProductSlug } from '../../../lib/products';

const db = await getDb();

let error = '';
let draft: Record<string, unknown> = {};

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const parsed = parseProductForm(form);
  if (parsed.error || !parsed.data) {
    error = parsed.error ?? 'Datos inválidos.';
    draft = Object.fromEntries(form.entries());
  } else {
    const d = parsed.data;
    const slug = await uniqueProductSlug(d.name);
    await db.execute({
      sql: `INSERT INTO products
              (name, slug, brand, description, price, old_price, image_url,
               category_id, cpu, ram, storage, screen, stock, featured)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
      args: [
        d.name, slug, d.brand, d.description, d.price, d.old_price, d.image_url,
        d.category_id, d.cpu, d.ram, d.storage, d.screen, d.stock, d.featured,
      ],
    });
    return Astro.redirect('/admin/productos');
  }
}

const categoriesRes = await db.execute('SELECT * FROM categories ORDER BY name');
const categories = categoriesRes.rows as unknown as Category[];
---

<AdminLayout title="Nuevo producto — NoteStore admin">
  <nav class="text-sm text-neutral-500">
    <a href="/admin/productos" class="hover:text-neutral-900">← Volver a productos</a>
  </nav>
  <h1 class="mt-3 mb-8 text-2xl font-bold tracking-tight">Nuevo producto</h1>
  <ProductForm product={draft} categories={categories} error={error} submitLabel="Crear producto" />
</AdminLayout>
