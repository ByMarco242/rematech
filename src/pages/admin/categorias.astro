---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb, type Category } from '../../lib/db';
import { slugify } from '../../lib/util';

const db = await getDb();
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'delete') {
    const id = Number(form.get('id'));
    if (Number.isInteger(id)) {
      await db.execute({ sql: 'DELETE FROM categories WHERE id = ?', args: [id] });
    }
    return Astro.redirect('/admin/categorias');
  }

  if (action === 'create') {
    const name = String(form.get('name') ?? '').trim();
    const description = String(form.get('description') ?? '').trim();
    const image_url = String(form.get('image_url') ?? '').trim();

    if (!name) {
      error = 'El nombre es obligatorio.';
    } else {
      const base = slugify(name) || 'categoria';
      let slug = base;
      let n = 2;
      for (;;) {
        const exists = await db.execute({
          sql: 'SELECT id FROM categories WHERE slug = ?',
          args: [slug],
        });
        if (exists.rows.length === 0) break;
        slug = `${base}-${n++}`;
      }
      await db.execute({
        sql: 'INSERT INTO categories (name, slug, description, image_url) VALUES (?, ?, ?, ?)',
        args: [name, slug, description, image_url],
      });
      return Astro.redirect('/admin/categorias');
    }
  }
}

const res = await db.execute(
  `SELECT c.*, COUNT(p.id) AS product_count
   FROM categories c LEFT JOIN products p ON p.category_id = c.id
   GROUP BY c.id ORDER BY c.name`
);
const categories = res.rows as unknown as (Category & { product_count: number })[];

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<AdminLayout title="Categorías — RemaTech admin">
  <h1 class="text-2xl font-bold tracking-tight">Categorías</h1>
  <p class="mt-1 text-sm text-neutral-500">
    Organizá el catálogo. Al eliminar una categoría, sus productos quedan sin categoría (no se borran).
  </p>

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
        {categories.length === 0 ? (
          <p class="p-10 text-center text-neutral-500">Todavía no hay categorías.</p>
        ) : (
          <table class="w-full text-sm">
            <thead class="border-b border-neutral-200 bg-neutral-50 text-left text-xs text-neutral-500 uppercase">
              <tr>
                <th class="px-5 py-3 font-medium">Categoría</th>
                <th class="px-5 py-3 font-medium">Productos</th>
                <th class="px-5 py-3 text-right font-medium">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
              {categories.map((c) => (
                <tr class="transition-colors hover:bg-neutral-50">
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-3">
                      <img src={c.image_url} alt="" class="size-10 shrink-0 rounded-lg object-cover" />
                      <div class="min-w-0">
                        <p class="font-medium">{c.name}</p>
                        <p class="truncate text-xs text-neutral-400">{c.description}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-5 py-3 text-neutral-500">{c.product_count}</td>
                  <td class="px-5 py-3">
                    <div class="flex items-center justify-end gap-1">
                      <a
                        href={`/categorias/${c.slug}`}
                        target="_blank"
                        class="rounded-lg px-3 py-1.5 text-xs font-semibold text-neutral-500 hover:bg-neutral-100"
                      >
                        Ver
                      </a>
                      <form
                        method="POST"
                        onsubmit={`return confirm('¿Eliminar la categoría «${c.name.replace(/'/g, '')}»?')`}
                      >
                        <input type="hidden" name="_action" value="delete" />
                        <input type="hidden" name="id" value={c.id} />
                        <button type="submit" class="cursor-pointer rounded-lg px-3 py-1.5 text-xs font-semibold text-rose-600 hover:bg-rose-50">
                          Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

    <div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
        <h2 class="font-bold">Nueva categoría</h2>
        {error && (
          <p class="mt-4 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
        )}
        <form method="POST" class="mt-4 space-y-4">
          <input type="hidden" name="_action" value="create" />
          <div>
            <label for="cat-name" class="mb-1.5 block text-sm font-medium text-neutral-700">Nombre *</label>
            <input id="cat-name" name="name" required class={input} placeholder="Ej: Gaming" />
          </div>
          <div>
            <label for="cat-desc" class="mb-1.5 block text-sm font-medium text-neutral-700">Descripción</label>
            <textarea id="cat-desc" name="description" rows="2" class={input} placeholder="Breve descripción..."></textarea>
          </div>
          <div>
            <label for="cat-img" class="mb-1.5 block text-sm font-medium text-neutral-700">URL de imagen</label>
            <input id="cat-img" name="image_url" type="url" class={input} placeholder="https://..." />
          </div>
          <button
            type="submit"
            class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
          >
            Crear categoría
          </button>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>
