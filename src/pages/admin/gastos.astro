---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';
import { formatPrice } from '../../lib/util';

const db = await getDb();
const me = Astro.locals.user!;

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'delete') {
    const id = Number(form.get('id'));
    if (Number.isInteger(id)) {
      await db.execute({ sql: 'DELETE FROM expenses WHERE id = ?', args: [id] });
    }
    return Astro.redirect('/admin/gastos');
  }

  if (action === 'create') {
    const date = String(form.get('expense_date') ?? '').trim();
    const category = String(form.get('category') ?? 'General').trim().slice(0, 60) || 'General';
    const description = String(form.get('description') ?? '').trim().slice(0, 200);
    const amount = Number(form.get('amount'));

    if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
      error = 'La fecha no es válida.';
    } else if (!Number.isFinite(amount) || amount <= 0) {
      error = 'El monto no es válido.';
    } else if (!description) {
      error = 'Agregá una descripción.';
    } else {
      await db.execute({
        sql: `INSERT INTO expenses (expense_date, category, description, amount, user_name)
              VALUES (?, ?, ?, ?, ?)`,
        args: [date, category, description, amount, me.name],
      });
      return Astro.redirect('/admin/gastos');
    }
  }
}

const [listRes, totalsRes] = await Promise.all([
  db.execute('SELECT * FROM expenses ORDER BY expense_date DESC, id DESC LIMIT 100'),
  db.execute(
    `SELECT COALESCE(SUM(amount), 0) AS total,
            COALESCE(SUM(CASE WHEN expense_date >= date('now', 'start of month') THEN amount END), 0) AS month
     FROM expenses`
  ),
]);

const expenses = listRes.rows as unknown as {
  id: number;
  expense_date: string;
  category: string;
  description: string;
  amount: number;
  user_name: string;
}[];
const totals = totalsRes.rows[0];

const today = new Date().toISOString().slice(0, 10);
const categories = ['General', 'Alquiler', 'Sueldos', 'Servicios', 'Envíos', 'Publicidad', 'Impuestos', 'Compras varias'];

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
---

<AdminLayout title="Gastos — NoteStore admin">
  <h1 class="text-2xl font-bold tracking-tight">Gastos operativos</h1>
  <p class="mt-1 text-sm text-neutral-500">
    Registrá los gastos del negocio para calcular la ganancia neta en Métricas.
  </p>

  <div class="mt-6 grid grid-cols-2 gap-4 lg:max-w-md">
    <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-neutral-500">Gastos este mes</p>
      <p class="mt-1 text-2xl font-extrabold break-words">{formatPrice(Number(totals.month))}</p>
    </div>
    <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-neutral-500">Gastos totales</p>
      <p class="mt-1 text-2xl font-extrabold break-words">{formatPrice(Number(totals.total))}</p>
    </div>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    <div>
      <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
        <h2 class="font-bold">Nuevo gasto</h2>
        {error && (
          <p class="mt-4 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
        )}
        <form method="POST" class="mt-4 space-y-4">
          <input type="hidden" name="_action" value="create" />
          <div>
            <label for="g-fecha" class="mb-1.5 block text-sm font-medium text-neutral-700">Fecha</label>
            <input id="g-fecha" name="expense_date" type="date" required value={today} class={input} />
          </div>
          <div>
            <label for="g-cat" class="mb-1.5 block text-sm font-medium text-neutral-700">Categoría</label>
            <select id="g-cat" name="category" class={input}>
              {categories.map((c) => <option value={c}>{c}</option>)}
            </select>
          </div>
          <div>
            <label for="g-desc" class="mb-1.5 block text-sm font-medium text-neutral-700">Descripción *</label>
            <input id="g-desc" name="description" required class={input} placeholder="Ej: Alquiler local julio" />
          </div>
          <div>
            <label for="g-monto" class="mb-1.5 block text-sm font-medium text-neutral-700">Monto (Gs.) *</label>
            <input id="g-monto" name="amount" type="number" min="1" step="1" required class={input} placeholder="1500000" />
          </div>
          <button
            type="submit"
            class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
          >
            Registrar gasto
          </button>
        </form>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="overflow-x-auto rounded-2xl border border-neutral-200 bg-white shadow-sm">
        <table class="w-full min-w-140 text-sm">
          <thead class="border-b border-neutral-200 bg-neutral-50 text-left text-xs text-neutral-500 uppercase">
            <tr>
              <th class="px-5 py-3 font-medium">Fecha</th>
              <th class="px-5 py-3 font-medium">Categoría</th>
              <th class="px-5 py-3 font-medium">Descripción</th>
              <th class="px-5 py-3 text-right font-medium">Monto</th>
              <th class="px-5 py-3 text-right font-medium"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {expenses.length === 0 ? (
              <tr><td colspan="5" class="p-10 text-center text-neutral-500">Todavía no hay gastos registrados.</td></tr>
            ) : (
              expenses.map((g) => (
                <tr class="transition-colors hover:bg-neutral-50">
                  <td class="px-5 py-3 whitespace-nowrap text-neutral-500">{g.expense_date}</td>
                  <td class="px-5 py-3">
                    <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-xs font-semibold text-neutral-600">{g.category}</span>
                  </td>
                  <td class="px-5 py-3">{g.description}</td>
                  <td class="px-5 py-3 text-right font-semibold whitespace-nowrap">{formatPrice(g.amount)}</td>
                  <td class="px-5 py-3 text-right">
                    <form method="POST" onsubmit={`return confirm('¿Eliminar este gasto de ${g.expense_date}?')`}>
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={g.id} />
                      <button type="submit" class="cursor-pointer rounded-lg px-3 py-1.5 text-xs font-semibold text-rose-600 hover:bg-rose-50">
                        Eliminar
                      </button>
                    </form>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>
