---
import BaseLayout from '../layouts/BaseLayout.astro';
import { registerUser, createSession, validatePassword } from '../lib/auth';
import { sanitizeNext } from '../lib/util';
import { isRateLimited, recordAttempt, clientIp } from '../lib/ratelimit';

const next = sanitizeNext(Astro.url.searchParams.get('next'));
if (Astro.locals.user) return Astro.redirect(next);

const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

let error = '';
let name = '';
let email = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  name = String(form.get('name') ?? '').trim().slice(0, 80);
  email = String(form.get('email') ?? '').trim().toLowerCase().slice(0, 254);
  const password = String(form.get('password') ?? '').slice(0, 100);

  const ipKey = `registro-ip:${clientIp(Astro.request)}`;

  const passwordError = validatePassword(password);

  if (!name || !email || !password) {
    error = 'Completá todos los campos.';
  } else if (!EMAIL_RE.test(email)) {
    error = 'El email no es válido.';
  } else if (passwordError) {
    error = passwordError;
  } else if (await isRateLimited(ipKey, 10, 60)) {
    error = 'Demasiados registros desde esta conexión. Probá más tarde.';
  } else {
    await recordAttempt(ipKey);
    const result = await registerUser(name, email, password);
    if (result.error) {
      error = result.error;
    } else if (result.user) {
      await createSession(result.user.id, Astro.cookies);
      return Astro.redirect(sanitizeNext(form.get('next')));
    }
  }
}
---

<BaseLayout title="Crear cuenta — NoteStore">
  <div class="mx-auto flex max-w-md flex-col px-4 py-16 sm:px-6">
    <div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm sm:p-10">
      <h1 class="text-2xl font-bold tracking-tight">Creá tu cuenta</h1>
      <p class="mt-2 text-sm text-neutral-500">
        ¿Ya tenés cuenta?
        <a href={`/login${next !== '/' ? `?next=${encodeURIComponent(next)}` : ''}`} class="font-semibold text-neutral-900 hover:underline">
          Ingresá
        </a>
      </p>

      {error && (
        <p class="mt-5 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>
      )}

      <form method="POST" class="mt-6 space-y-4">
        <input type="hidden" name="next" value={next} />
        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-neutral-700">Nombre</label>
          <input
            id="name"
            type="text"
            name="name"
            value={name}
            required
            autocomplete="name"
            class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-neutral-700">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            value={email}
            required
            autocomplete="email"
            class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
            placeholder="tu@email.com"
          />
        </div>
        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-neutral-700">Contraseña</label>
          <input
            id="password"
            type="password"
            name="password"
            required
            minlength="8"
            maxlength="100"
            autocomplete="new-password"
            class="w-full rounded-xl border border-neutral-200 px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200"
            placeholder="Tu contraseña"
          />
          <ul id="pw-checks" class="mt-2 space-y-1 text-xs text-neutral-400">
            <li data-check="len"><span class="inline-block w-4">•</span>Al menos 8 caracteres</li>
            <li data-check="lower"><span class="inline-block w-4">•</span>Una letra minúscula</li>
            <li data-check="upper"><span class="inline-block w-4">•</span>Una letra mayúscula</li>
            <li data-check="num"><span class="inline-block w-4">•</span>Un número</li>
          </ul>
        </div>
        <button
          type="submit"
          class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
        >
          Crear cuenta
        </button>
      </form>
    </div>
  </div>

  <script is:inline>
    (() => {
      const input = document.getElementById('password');
      const list = document.getElementById('pw-checks');
      if (!input || !list) return;

      const rules = {
        len: (v) => v.length >= 8,
        lower: (v) => /[a-z]/.test(v),
        upper: (v) => /[A-Z]/.test(v),
        num: (v) => /[0-9]/.test(v),
      };

      input.addEventListener('input', () => {
        const value = input.value;
        for (const [name, test] of Object.entries(rules)) {
          const item = list.querySelector(`[data-check="${name}"]`);
          if (!item) continue;
          const ok = test(value);
          item.classList.toggle('text-emerald-600', ok);
          item.classList.toggle('text-neutral-400', !ok);
          item.querySelector('span').textContent = ok ? '✓' : '•';
        }
      });
    })();
  </script>
</BaseLayout>
