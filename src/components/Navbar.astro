---
const user = Astro.locals.user;
const path = Astro.url.pathname;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/productos', label: 'Notebooks' },
  { href: '/contacto', label: 'Contacto' },
];

function isActive(href: string) {
  return href === '/' ? path === '/' : path.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-neutral-200/70 bg-white/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-6 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-bold tracking-tight text-neutral-900">
      <span class="flex size-8 items-center justify-center rounded-lg bg-gradient-to-br from-neutral-700 to-neutral-950 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>
      </span>
      <span class="text-lg">Note<span class="text-neutral-500">Store</span></span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'rounded-full px-4 py-1.5 text-sm font-medium transition-colors',
            isActive(l.href)
              ? 'bg-neutral-100 text-neutral-900'
              : 'text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900',
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a
        href="/carrito"
        class="relative flex size-10 items-center justify-center rounded-full text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
        aria-label="Carrito"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <span
          data-cart-badge
          class="absolute -top-0.5 -right-0.5 hidden min-w-4.5 items-center justify-center rounded-full bg-neutral-900 px-1 text-[10px] font-bold text-white"
        ></span>
      </a>

      {user ? (
        <div class="flex items-center gap-2">
          {user.is_staff && (
            <a
              href="/admin"
              class="hidden rounded-full border border-neutral-200 px-4 py-1.5 text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-50 sm:block"
            >
              Panel admin
            </a>
          )}
          <a href="/cuenta" class="hidden rounded-full px-3 py-1.5 text-sm font-medium text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900 sm:block">
            Hola, {user.name.split(' ')[0]}
          </a>
          <form method="POST" action="/api/logout">
            <button
              type="submit"
              class="rounded-full bg-neutral-900 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-neutral-700"
            >
              Salir
            </button>
          </form>
        </div>
      ) : (
        <div class="flex items-center gap-2">
          <a
            href="/login"
            class="rounded-full px-4 py-1.5 text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-100"
          >
            Ingresar
          </a>
          <a
            href="/registro"
            class="rounded-full bg-neutral-900 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-neutral-700"
          >
            Crear cuenta
          </a>
        </div>
      )}
    </div>
  </div>
</header>
