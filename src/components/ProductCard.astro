---
import type { Product } from '../lib/db';
import { formatPrice } from '../lib/util';

interface Props {
  product: Product;
  badge?: string;
}

const { product, badge } = Astro.props;

const cartPayload = JSON.stringify({
  id: product.id,
  name: product.name,
  price: product.price,
  image: product.image_url,
  slug: product.slug,
});

const specs = [product.cpu, product.ram, product.storage].filter(Boolean);
const onSale = product.old_price != null && product.old_price > product.price;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-neutral-200/60">
  <a href={`/productos/${product.slug}`} class="relative block aspect-[4/3] overflow-hidden bg-neutral-100">
    <img
      src={product.image_url}
      alt={product.name}
      loading="lazy"
      class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    {badge && (
      <span class="absolute top-3 left-3 rounded-full bg-neutral-900 px-3 py-1 text-xs font-semibold text-white shadow">
        {badge}
      </span>
    )}
    {onSale && (
      <span class="absolute top-3 right-3 rounded-full bg-rose-500 px-3 py-1 text-xs font-semibold text-white shadow">
        Oferta
      </span>
    )}
    {product.stock <= 0 && (
      <span class="absolute inset-0 flex items-center justify-center bg-white/70 text-sm font-semibold text-neutral-700 backdrop-blur-sm">
        Sin stock
      </span>
    )}
  </a>

  <div class="flex flex-1 flex-col gap-2 p-4">
    <p class="text-xs font-medium tracking-wide text-neutral-400 uppercase">{product.brand}</p>
    <a href={`/productos/${product.slug}`} class="font-semibold text-neutral-900 transition-colors hover:text-neutral-500">
      {product.name}
    </a>

    {specs.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {specs.map((s) => (
          <span class="rounded-md bg-neutral-100 px-2 py-0.5 text-[11px] font-medium text-neutral-600">{s}</span>
        ))}
      </div>
    )}

    <div class="mt-auto flex items-end justify-between pt-3">
      <div>
        {onSale && (
          <p class="text-xs text-neutral-400 line-through">{formatPrice(product.old_price!)}</p>
        )}
        <p class="text-lg font-bold text-neutral-900">{formatPrice(product.price)}</p>
      </div>
      {product.stock > 0 && (
        <button
          type="button"
          data-add-to-cart={cartPayload}
          class="flex size-9 cursor-pointer items-center justify-center rounded-full bg-neutral-900 text-white transition-colors hover:bg-neutral-700"
          aria-label={`Agregar ${product.name} al carrito`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        </button>
      )}
    </div>
  </div>
</article>
