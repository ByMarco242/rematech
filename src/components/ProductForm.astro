---
import type { Category, Product } from '../lib/db';

interface Props {
  product?: Partial<Product>;
  categories: Category[];
  error?: string;
  submitLabel: string;
}

const { product = {}, categories, error, submitLabel } = Astro.props;

const input =
  'w-full rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm outline-none focus:border-neutral-500 focus:ring-2 focus:ring-neutral-200';
const label = 'mb-1.5 block text-sm font-medium text-neutral-700';
---

{error && <p class="mb-6 rounded-xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-600">{error}</p>}

<form method="POST" class="grid gap-6 lg:grid-cols-3">
  <div class="space-y-5 lg:col-span-2">
    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="font-bold">Información general</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="name" class={label}>Nombre *</label>
          <input id="name" name="name" required value={product.name ?? ''} class={input} placeholder="Ej: Lenovo Legion 5 Pro" />
        </div>
        <div>
          <label for="brand" class={label}>Marca</label>
          <input id="brand" name="brand" value={product.brand ?? ''} class={input} placeholder="Ej: Lenovo" />
        </div>
        <div>
          <label for="category_id" class={label}>Categoría</label>
          <select id="category_id" name="category_id" class={input}>
            <option value="">Sin categoría</option>
            {categories.map((c) => (
              <option value={c.id} selected={c.id === product.category_id}>{c.name}</option>
            ))}
          </select>
        </div>
        <div class="sm:col-span-2">
          <label for="description" class={label}>Descripción</label>
          <textarea id="description" name="description" rows="4" class={input} placeholder="Descripción del producto...">{product.description ?? ''}</textarea>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="font-bold">Especificaciones</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div>
          <label for="cpu" class={label}>Procesador</label>
          <input id="cpu" name="cpu" value={product.cpu ?? ''} class={input} placeholder="Ej: Ryzen 7 7745HX" />
        </div>
        <div>
          <label for="ram" class={label}>Memoria RAM</label>
          <input id="ram" name="ram" value={product.ram ?? ''} class={input} placeholder="Ej: 16GB DDR5" />
        </div>
        <div>
          <label for="storage" class={label}>Almacenamiento</label>
          <input id="storage" name="storage" value={product.storage ?? ''} class={input} placeholder="Ej: 512GB SSD NVMe" />
        </div>
        <div>
          <label for="screen" class={label}>Pantalla</label>
          <input id="screen" name="screen" value={product.screen ?? ''} class={input} placeholder='Ej: 16" 2K 165Hz' />
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-5">
    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="font-bold">Precio y stock</h2>
      <div class="mt-4 space-y-4">
        <div>
          <label for="price" class={label}>Precio (Gs.) *</label>
          <input id="price" name="price" type="number" step="1" min="0" required value={product.price ?? ''} class={input} placeholder="7500000" />
        </div>
        <div>
          <label for="old_price" class={label}>Precio anterior <span class="text-neutral-400">(para mostrar oferta)</span></label>
          <input id="old_price" name="old_price" type="number" step="1" min="0" value={product.old_price ?? ''} class={input} placeholder="Opcional" />
        </div>
        <div>
          <label for="stock" class={label}>Stock</label>
          <input id="stock" name="stock" type="number" min="0" value={product.stock ?? 0} class={input} />
        </div>
        <label class="flex cursor-pointer items-center gap-2.5 text-sm font-medium text-neutral-700">
          <input
            type="checkbox"
            name="featured"
            checked={Boolean(product.featured)}
            class="size-4 rounded accent-neutral-900"
          />
          Producto destacado (aparece en el hero de la portada)
        </label>
      </div>
    </div>

    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="font-bold">Imagen</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label for="image_url" class={label}>URL de la imagen</label>
          <input
            id="image_url"
            name="image_url"
            type="url"
            value={product.image_url ?? ''}
            class={input}
            placeholder="https://..."
            oninput="document.getElementById('img-preview').src = this.value"
          />
        </div>
        <img
          id="img-preview"
          src={product.image_url || 'https://placehold.co/600x450/e4e4e7/a1a1aa?text=Sin+imagen'}
          alt="Vista previa"
          class="aspect-[4/3] w-full rounded-xl border border-neutral-200 object-cover"
          onerror="this.src='https://placehold.co/600x450/e4e4e7/a1a1aa?text=Sin+imagen'"
        />
      </div>
    </div>

    <button
      type="submit"
      class="w-full cursor-pointer rounded-xl bg-neutral-900 py-3 font-semibold text-white transition-colors hover:bg-neutral-700"
    >
      {submitLabel}
    </button>
  </div>
</form>
