# Base de datos (en desarrollo se usa file:local.db por defecto, no hace falta configurar nada)
# Para producción en Vercel: crear una base en https://turso.tech y copiar estos valores
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-token

# Número de WhatsApp de la tienda (con código de país, sin +, espacios ni guiones)
# Los pedidos del carrito se envían a este número. Ej. Paraguay: 595971123456
WHATSAPP_NUMBER=595985752720

# Opcional: envío de emails de recuperación de contraseña vía https://resend.com
# Sin esto, la recuperación queda en manos del admin (botón "Resetear clave" en Usuarios)
RESEND_API_KEY=
MAIL_FROM=NoteStore <onboarding@resend.dev>
